<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.github.IrineSistiana.shadowsocks.plugin">

    <application
        android:allowBackup="false"
        android:extractNativeLibs="true"
        android:label="@string/app_name">

        <provider
            android:name="com.github.IrineSistiana.shadowsocks.plugin.simple_tls.BinaryProvider"
            android:authorities="com.github.IrineSistiana.shadowsocks.plugin.simple_tls.BinaryProvider"
            android:exported="true">

            <intent-filter>
                <action android:name="com.github.shadowsocks.plugin.ACTION_NATIVE_PLUGIN" />
            </intent-filter>

            <meta-data
                android:name="com.github.shadowsocks.plugin.id"
                android:value="@string/plugin_id" />

            <meta-data
                android:name="com.github.shadowsocks.plugin.executable_path"
                android:value="@string/plugin_lib_path" />
        </provider>

    </application>
</manifest>
